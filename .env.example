# Copy to backend/.env and fill in real values.

# Required — get a free sandbox key at https://developer.va.gov/apply
VA_API_KEY=your_va_sandbox_key_here

# Optional — enables the LLM-powered assistant. Without it, the app
# falls back to keyword parsing so nothing breaks.
OPENAI_API_KEY=

# Optional overrides
VA_API_BASE_URL=https://sandbox-api.va.gov/services/va_facilities/v1
