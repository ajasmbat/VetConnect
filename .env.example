# Copy to backend/.env and fill in real values.

# ---- Required ---------------------------------------------------------------

# Get a free sandbox key at https://developer.va.gov/apply
VA_API_KEY=your_va_sandbox_key_here

# ---- Optional: LLM assistant ------------------------------------------------

# If unset, the app uses keyword parsing + template answers (still fully works).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Chat/completions endpoint. Override to point at Azure OpenAI, a LiteLLM
# proxy, or a self-hosted OpenAI-compatible server.
OPENAI_API_BASE_URL=https://api.openai.com/v1/chat/completions

# ---- Optional overrides -----------------------------------------------------

# Which VA environment to hit. Sandbox is fine for the demo.
VA_API_BASE_URL=https://sandbox-api.va.gov/services/va_facilities/v1

# The single frontend origin allowed to call this API (CORS). Change when you
# deploy the frontend somewhere other than the Vite dev server.
CORS_ORIGIN=http://localhost:5173

# Where the local SQLite cache/log file lives (relative to the backend dir).
SQLITE_PATH=vetconnect.db

# Per-IP rate limits for /api/assistant. Guards the OpenAI budget from
# bursty scrapers. Applied even when OpenAI isn't configured.
ASSISTANT_RATE_PER_MINUTE=10
ASSISTANT_RATE_PER_HOUR=60

# Geocoder (Nominatim / OpenStreetMap).
# Override NOMINATIM_USER_AGENT to something identifying YOUR deployment —
# Nominatim's abuse policy rejects generic UAs with HTTP 403.
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=VetConnect-Dev/1.0 (+https://github.com/ajasmbat/VetConnect)
